# ============================================
# Domdhi.Agents — System Ignores
# ============================================

# Dependencies
node_modules/

# Environment / secrets
# (defense-in-depth; the pre-commit secret scanner is the real gate)
.env
.env.*
!.env.example
!.env.*.example
*.local.*

# Temp / Logs
*.log
*.bak
*.tmp
.archive

# Runtime artifacts
# Anchored to root with leading slash so the tracked template version at
# .claude/templates/root/.playwright/ remains visible to git.
/.playwright*/

# Ephemeral output (rebuilt from source or session-specific)
# Tracked (NOT listed here): plans/, reviews/, research/, investigations/, work/
.claude/.agents.docs/
docs/.output/memories/
docs/.output/screenshots*/
docs/.output/sessions*/
docs/.output/telemetry*/
docs/.output/telemetry/coverage/
